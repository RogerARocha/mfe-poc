{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "paths": {
      "shared-ui": ["./dist/shared-ui"]
    },
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/host/tsconfig.app.json"
    },
    {
      "path": "./projects/host/tsconfig.spec.json"
    },
    {
      "path": "./projects/finance/tsconfig.app.json"
    },
    {
      "path": "./projects/finance/tsconfig.spec.json"
    },
    {
      "path": "./projects/hr/tsconfig.app.json"
    },
    {
      "path": "./projects/hr/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared-ui/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared-ui/tsconfig.spec.json"
    }
  ]
}
